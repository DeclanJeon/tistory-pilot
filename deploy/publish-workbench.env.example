PUBLISH_WORKBENCH_APP_ENV=production
PUBLISH_WORKBENCH_DATA_ROOT=/srv/publish-workbench/data
PUBLISH_WORKBENCH_BASE_URL=https://publish.ponslink.com
PUBLISH_WORKBENCH_LOG_LEVEL=info
PUBLISH_WORKBENCH_SESSION_SECRET=change-me

PUBLISH_WORKBENCH_AUTH_EMAIL_ENABLED=0
PUBLISH_WORKBENCH_AUTH_EMAIL_FROM=
PUBLISH_WORKBENCH_AUTH_EMAIL_SMTP_HOST=
PUBLISH_WORKBENCH_AUTH_EMAIL_SMTP_PORT=587
PUBLISH_WORKBENCH_AUTH_EMAIL_SMTP_SECURE=0
PUBLISH_WORKBENCH_AUTH_EMAIL_SMTP_USER=
PUBLISH_WORKBENCH_AUTH_EMAIL_SMTP_PASS=
PUBLISH_WORKBENCH_AUTH_EMAIL_ALLOWED_RECIPIENTS=ops@ponslink.com
PUBLISH_WORKBENCH_AUTH_EMAIL_CODE_TTL_MS=600000

PUBLISH_WORKBENCH_WEB_HOST=127.0.0.1
PUBLISH_WORKBENCH_WEB_PORT=4310
PUBLISH_WORKBENCH_WEB_TRUST_PROXY=1

PUBLISH_WORKBENCH_WORKER_ID=ponslink-worker-1
PUBLISH_WORKBENCH_WORKER_POLL_MS=2000
PUBLISH_WORKBENCH_BROWSER_PROFILE_DIR=/srv/publish-workbench/browser-profile
PUBLISH_WORKBENCH_BROWSER_HEADLESS=1

PUBLISH_WORKBENCH_LOCK_LEASE_MS=90000
PUBLISH_WORKBENCH_LOCK_HEARTBEAT_MS=30000
PUBLISH_WORKBENCH_STAGED_SUCCESS_TTL_MS=86400000
PUBLISH_WORKBENCH_STAGED_FAILURE_TTL_MS=259200000
PUBLISH_WORKBENCH_QR_TTL_MS=3600000

PUBLISH_WORKBENCH_QR_EMAIL_ENABLED=0
PUBLISH_WORKBENCH_QR_EMAIL_FROM=
PUBLISH_WORKBENCH_QR_EMAIL_SMTP_HOST=
PUBLISH_WORKBENCH_QR_EMAIL_SMTP_PORT=587
PUBLISH_WORKBENCH_QR_EMAIL_SMTP_SECURE=0
PUBLISH_WORKBENCH_QR_EMAIL_SMTP_USER=
PUBLISH_WORKBENCH_QR_EMAIL_SMTP_PASS=
PUBLISH_WORKBENCH_QR_EMAIL_ALLOWED_RECIPIENTS=ops@ponslink.com
