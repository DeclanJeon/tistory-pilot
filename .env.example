# Optional: reuse SMTP + owner email from another project env file.
# Example: /home/declan/Documents/Develop/Project/pons_p2p/ponslink-api-infra/.env
TISTORY_ENV_FILE=
TISTORY_BLOG_URL=https://YOURBLOG.tistory.com
TISTORY_POST_TITLE=agbrowse test post
TISTORY_POST_BODY=첫 번째 줄\n\n두 번째 줄
TISTORY_POST_DESCRIPTION=간단한 설명
TISTORY_POST_TAGS=agbrowse,tistory,automation
TISTORY_POST_CATEGORY=IT·테크
TISTORY_POST_HERO_IMAGE=assets/example.png
TISTORY_HEADED=1
TISTORY_QR_IMAGE_PATH=tmp/kakao-tistory-qr.png
TISTORY_WAIT_FOR_LOGIN_MS=300000
TISTORY_QR_EMAIL_TO=
TISTORY_QR_EMAIL_ON_REFRESH=0
TISTORY_QR_EMAIL_SUBJECT_PREFIX=[Tistory QR]
TISTORY_QR_EMAIL_FROM=
TISTORY_SMTP_HOST=
TISTORY_SMTP_PORT=587
TISTORY_SMTP_SECURE=0
TISTORY_SMTP_USER=
TISTORY_SMTP_PASS=
# Compatibility: the QR mailer also accepts SMTP_HOST/SMTP_PORT/SMTP_SECURE/SMTP_USER/SMTP_PASS/SMTP_FROM
# and will fall back to PONSLINK_PROVIDER_DASHBOARD_OWNER_EMAIL or CONTACT_EMAIL as the recipient when available.
TISTORY_SOURCE_URLS=https://example.com/article-a,https://example.com/article-b
TISTORY_SOURCE_OUTPUT_DIR=tmp/source-imports
TISTORY_SOURCE_IMAGE_LIMIT=3
TISTORY_SOURCE_PARAGRAPHS=12
TISTORY_SOURCE_IMAGE_EVERY=3
TISTORY_DOWNLOAD_SOURCE_HERO=1
